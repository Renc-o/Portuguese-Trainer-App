{
  "expo": {
    "name": "Portuguese Trainer",
    "slug": "portugais-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/iconPT.jpg",
    "scheme": "portugaisapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/iconPT.jpg",
        "backgroundImage": "./assets/images/iconPT.jpg",
        "monochromeImage": "./assets/images/iconPT.jpg"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.renc_o.portugaisapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7af9ff7f-b5e6-4d79-a52d-ff2abb87dec3"
      }
    },
    "owner": "renc_o"
  }
}
